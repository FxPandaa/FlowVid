# ============================================================================
# FlowVid API — Environment Variables
# Copy this to .env and fill in your values
# Generate keys with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Bind address — 127.0.0.1 (recommended with Cloudflare Tunnel, no direct exposure)
# Use 0.0.0.0 if you need LAN access without a tunnel
BIND_HOST=127.0.0.1

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Set to "true" when exposing via Cloudflare Tunnel. Effects:
#   - Rate limiter uses CF-Connecting-IP header for real client IPs
#   - /internal/* routes restricted to localhost only (inaccessible via tunnel)
CLOUDFLARE_TUNNEL=true

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate a unique random key (see command above)
JWT_SECRET=CHANGE_ME_generate_random_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Database ─────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file
DATABASE_PATH=/flowvid/data/flowvid.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add your domain when you have one (e.g. https://flowvid.com)
# tauri:// is required for the desktop app
CORS_ORIGINS=tauri://localhost,http://localhost:1420,http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# ── Cache ────────────────────────────────────────────────────────────────────
METADATA_CACHE_TTL=86400

# ── Automated Backups ────────────────────────────────────────────────────────
# SQLite backups with retention policy
BACKUP_ENABLED=true
BACKUP_DIR=/flowvid/backups
BACKUP_INTERVAL_HOURS=6
BACKUP_RETENTION_DAYS=30

# ── Static Website (optional) ───────────────────────────────────────────────
# Set to a directory path to serve a static website at the root URL
# Leave empty to disable (API info JSON is shown at / instead)
WEBSITE_DIR=

# ── App Version & Updates ───────────────────────────────────────────────────
# Current latest app version (semver)
APP_VERSION=1.0.0
# Minimum version clients must run (force-update below this)
MIN_APP_VERSION=1.0.0
# Release notes shown to users when an update is available
UPDATE_NOTES=
# Base URL where Tauri update bundles are hosted
# e.g. https://releases.flowvid.com or https://github.com/you/flowvid/releases/download
TAURI_UPDATE_URL=
# Local directory containing .sig files for Tauri update signature verification
# Leave empty if signatures are not used (pubkey must also be empty in tauri.conf.json)
TAURI_SIGNATURE_DIR=

# ── Dodo Payments (Merchant of Record — no KVK/business registration needed) ─
# Dashboard: https://app.dodopayments.com
# Leave as "placeholder" to disable billing (free mode only)
DODO_API_KEY=placeholder
DODO_WEBHOOK_SECRET=placeholder
DODO_PRODUCT_ID=placeholder
DODO_SUCCESS_URL=http://localhost:1420/settings?payment=success
DODO_CANCEL_URL=http://localhost:1420/settings?payment=canceled

# ── TorBox Vendor (FlowVid+ debrid provisioning) ────────────────────────────
# Leave empty to disable TorBox provisioning
TORBOX_VENDOR_API_KEY=
# REQUIRED: Generate a unique random key (see command at top)
TORBOX_ENCRYPTION_KEY=CHANGE_ME_generate_random_key

# ── Internal/Operator API ───────────────────────────────────────────────────
# Used for /internal/* routes (backup, reconciliation, etc.)
# When CLOUDFLARE_TUNNEL=true, these are localhost-only regardless
# REQUIRED: Generate a unique random key (see command at top)
INTERNAL_API_KEY=CHANGE_ME_generate_random_key
