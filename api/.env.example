# ============================================================================
# flowvid API - Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=flowvid-dev-secret-change-in-production-32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Database
DATABASE_PATH=./data/flowvid.db

# CORS
CORS_ORIGINS=http://localhost:1420,http://localhost:3000,tauri://localhost

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache
METADATA_CACHE_TTL=86400

# ============================================================================
# BILLING & TORBOX VENDOR (New)
# ============================================================================

# Dodo Payments (Merchant of Record — no KVK needed)
# Dashboard: https://app.dodopayments.com
DODO_API_KEY=placeholder
DODO_WEBHOOK_SECRET=placeholder
DODO_PRODUCT_ID=placeholder
DODO_SUCCESS_URL=http://localhost:1420/settings?payment=success
DODO_CANCEL_URL=http://localhost:1420/settings?payment=canceled

# TorBox Vendor API (get from TorBox Partners dashboard)
TORBOX_VENDOR_API_KEY=
TORBOX_ENCRYPTION_KEY=flowvid-dev-encryption-key-change-in-prod

# Internal/Operator API Key (for /internal/* routes)
# Leave empty in dev to allow unauthenticated access
INTERNAL_API_KEY=
