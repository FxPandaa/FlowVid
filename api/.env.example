# ============================================================================
# FlowVid API — Environment Variables
# Copy this to .env and fill in your values
# Generate keys with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── JWT Auth ─────────────────────────────────────────────────────────────────
# REQUIRED: Generate a unique random key (see command above)
JWT_SECRET=CHANGE_ME_generate_random_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Database ─────────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file
DATABASE_PATH=/flowvid/data/flowvid.db

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Local network: add your mini PC IP (e.g. http://192.168.1.100:3000)
# VPS/production: add your domain (e.g. https://api.flowvid.com)
# tauri:// is required for the desktop app
CORS_ORIGINS=tauri://localhost,http://localhost:1420,http://localhost:5173

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ── Cache ────────────────────────────────────────────────────────────────────
METADATA_CACHE_TTL=86400

# ── Dodo Payments (Merchant of Record — no KVK/business registration needed) ─
# Dashboard: https://app.dodopayments.com
# Leave as "placeholder" to disable billing (free mode only)
DODO_API_KEY=placeholder
DODO_WEBHOOK_SECRET=placeholder
DODO_PRODUCT_ID=placeholder
DODO_SUCCESS_URL=http://localhost:1420/settings?payment=success
DODO_CANCEL_URL=http://localhost:1420/settings?payment=canceled

# ── TorBox Vendor (FlowVid+ debrid provisioning) ────────────────────────────
# Leave empty to disable TorBox provisioning
TORBOX_VENDOR_API_KEY=
# REQUIRED: Generate a unique random key (see command at top)
TORBOX_ENCRYPTION_KEY=CHANGE_ME_generate_random_key

# ── Internal/Operator API ───────────────────────────────────────────────────
# Used for /internal/* routes (backup, reconciliation, etc.)
# REQUIRED: Generate a unique random key (see command at top)
INTERNAL_API_KEY=CHANGE_ME_generate_random_key
